# Required for TensorZero to call Moonshot / Kimi models
MOONSHOT_API_KEY=sk-...

# Database: SQLite (default for local dev) or Postgres (Docker)
# DATABASE_URL=sqlite:routage.db
# DATABASE_URL=postgres://routage:routage@localhost:5432/routage

# Optional: override TensorZero gateway URL (default: http://localhost:3000/openai/v1)
# TENSORZERO_URL=http://localhost:3000/openai/v1

# Optional: routage settings
# BIND_ADDR=0.0.0.0:8080
# RUST_LOG=routage=debug
